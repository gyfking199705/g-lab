{
  "name": "muse-ui",
  "version": "0.1.0",
  "description": "✨ UI 组件脑爆 + research 实验室：零依赖 React 创意交互组件（3D 倾斜 / 光斑 / 磁吸 / 涟漪 / 动态网格渐变 / 数字滚动），可被 planner 复用、也可发 npm。",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src", "README.md"],
  "sideEffects": false,
  "keywords": [
    "react",
    "ui",
    "components",
    "animation",
    "interaction",
    "tilt",
    "ripple",
    "magnetic",
    "spotlight",
    "gradient",
    "creative"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "build": "node build.mjs"
  }
}
